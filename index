    <div class="item-body">
      <p class="item-name">Ninho &amp; Nutella</p>
      <p class="item-desc">Brownie, morangos frescos, creme de Ninho e Nutella</p>
      <div class="badges"><span class="badge badge-fav">♥ Favorito</span></div>
    </div>
    <div class="item-price">R$ 20,00</div>
  </div>

  <div class="item">
    <img class="item-img" src="data:image/png;base64," alt="Escondidinho Brigadeiro 50%">
    <div class="item-body">

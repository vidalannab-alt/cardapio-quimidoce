<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Quimi Doce — Cardápio</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --vinho: #5C1A2E;
    --rose: #8B2E4A;
    --blush: #C0546A;
    --cream: #FFF7F2;
    --pale: #FDE8EC;
    --muted: #9A7070;
    --dark: #2D1208;
  }
  body { background: var(--cream); font-family: "DM Sans", sans-serif; color: var(--dark); }

  .hero {
    background: var(--vinho);
    padding: 3.5rem 2rem 5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .hero::after {
    content: "";
    position: absolute;
    bottom: -2px; left: -5%; right: -5%;
    height: 60px;
    background: var(--cream);
    border-radius: 50% 50% 0 0 / 100% 100% 0 0;
  }
  .hero-deco { position: absolute; border-radius: 50%; opacity: 0.07; background: #fff; }
  .hero-deco.a { width: 300px; height: 300px; top: -80px; left: -60px; }
  .hero-deco.b { width: 200px; height: 200px; bottom: 20px; right: -40px; }

  .logo-name {
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(3rem, 10vw, 5.5rem);
    font-weight: 600; color: #fff; letter-spacing: 2px; line-height: 1;
    animation: fadeDown 0.8s ease both;
  }
  .logo-sub {
    font-size: 0.7rem; letter-spacing: 6px; color: rgba(255,255,255,0.5);
    text-transform: uppercase; margin-top: 0.5rem;
    animation: fadeDown 0.8s 0.1s ease both;
  }
  .hero-tagline {
    font-family: "Cormorant Garamond", serif; font-style: italic;
    font-size: 1.1rem; color: rgba(255,255,255,0.6); margin-top: 1rem;
    animation: fadeDown 0.8s 0.2s ease both;
  }
  @keyframes fadeDown {
    from { opacity: 0; transform: translateY(-16px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .container { max-width: 680px; margin: 0 auto; padding: 2rem 1.25rem 4rem; }

  .section-title {
    display: flex; align-items: center; gap: 1rem;
    margin: 2.5rem 0 1.25rem;
  }
  .section-title::before, .section-title::after {
    content: ""; flex: 1; height: 1px;
    background: linear-gradient(to right, transparent, #E0B8C0, transparent);
  }
  .section-title span {
    font-family: "Cormorant Garamond", serif;
    font-size: 1.5rem; font-style: italic; color: var(--rose); white-space: nowrap;
  }

  .item {
    display: flex; align-items: center; gap: 1rem;
    padding: 0.85rem 1rem;
    background: #fff; border-radius: 14px; border: 1px solid #F0D5DA;
    margin-bottom: 0.65rem;
    transition: transform 0.18s, box-shadow 0.18s;
    animation: fadeUp 0.5s ease both;
  }
  .item:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(92,26,46,0.09); }

  .item-img {
    width: 80px; height: 80px; border-radius: 10px;
    object-fit: cover; flex-shrink: 0;
    border: 1px solid #F0D5DA;
  }
  .item-body { flex: 1; min-width: 0; }
  .item-name { font-size: 0.95rem; font-weight: 500; color: var(--dark); margin-bottom: 3px; }
  .item-desc { font-size: 0.78rem; color: var(--muted); line-height: 1.45; margin-bottom: 6px; }
  .badges { display: flex; gap: 5px; flex-wrap: wrap; }
  .badge {
    font-size: 0.6rem; font-weight: 500; padding: 2px 8px;
    border-radius: 99px; letter-spacing: 0.4px;
  }
  .badge-hit  { background: #ffd6e0; color: #7a1e3a; }
  .badge-spec { background: #d6ede0; color: #1a5e38; }
  .badge-fav  { background: #ffe8cc; color: #7a4010; }
  .item-price {
    font-family: "Cormorant Garamond", serif;
    font-size: 1.25rem; font-weight: 600; color: var(--rose);
    white-space: nowrap; flex-shrink: 0; padding-top: 2px;
  }

  .combo {
    background: var(--vinho); border-radius: 14px; padding: 1.1rem 1.25rem;
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    margin-bottom: 0.65rem; animation: fadeUp 0.5s ease both;
  }
  .combo-label {
    font-size: 0.6rem; letter-spacing: 4px; text-transform: uppercase;
    color: rgba(255,255,255,0.45); margin-bottom: 3px;
  }
  .combo-name {
    font-family: "Cormorant Garamond", serif;
    font-size: 1.1rem; font-style: italic; color: #fff; margin-bottom: 3px;
  }
  .combo-desc { font-size: 0.78rem; color: rgba(255,255,255,0.6); }
  .combo-price {
    font-family: "Cormorant Garamond", serif;
    font-size: 1.5rem; font-weight: 600; color: #FFD6E0; white-space: nowrap;
  }

  .info-strip {
    background: var(--pale); border-radius: 12px; padding: 0.85rem 1.25rem;
    text-align: center; font-size: 0.82rem; color: var(--rose);
    font-style: italic; margin-top: 1.5rem;
  }

  .footer {
    background: var(--dark); border-radius: 16px;
    padding: 1.25rem 1.5rem; margin-top: 1.25rem;
  }
  .footer-title {
    font-size: 0.6rem; letter-spacing: 4px; text-transform: uppercase;
    color: rgba(255,255,255,0.35); margin-bottom: 0.75rem;
  }
  .footer-row {
    display: flex; align-items: center; gap: 10px; margin-bottom: 0.5rem;
    font-size: 0.88rem; color: rgba(255,255,255,0.8); text-decoration: none;
  }
  .footer-row:last-child { margin-bottom: 0; }
  .footer-icon {
    width: 28px; height: 28px; border-radius: 50%;
    background: rgba(255,255,255,0.1);
    display: flex; align-items: center; justify-content: center;
    font-size: 0.75rem; color: #FFD6E0; font-weight: 500; flex-shrink: 0;
  }
  .item:nth-child(1) { animation-delay: 0.05s; }
  .item:nth-child(2) { animation-delay: 0.10s; }
  .item:nth-child(3) { animation-delay: 0.15s; }
  .item:nth-child(4) { animation-delay: 0.20s; }
  .item:nth-child(5) { animation-delay: 0.25s; }
  @media (max-width: 480px) {
    .combo { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
    .item-img { width: 68px; height: 68px; }
  }
</style>
</head>
<body>

<div class="hero">
  <div class="hero-deco a"></div>
  <div class="hero-deco b"></div>
  <h1 class="logo-name">Quimi Doce</h1>
  <p class="logo-sub">Doceria Artesanal</p>
  <p class="hero-tagline">Equilíbrio em cada detalhe</p>
</div>

<div class="container">

  <div class="section-title"><span>Pizza Brownie</span></div>

  <div class="item">
